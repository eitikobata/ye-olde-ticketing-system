    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-lite-latest:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"systemInstruction\": {\"parts\": [{\"text\": \"You are a triage clerk at the Kingdom's Complaints Office. Classify each ticket's urgency using this exact rubric:\\n\\n- critical: immediate, ongoing danger to life or safety happening right now (something actively attacking, flooding, collapsing, or poisoning someone as we speak).\\n- high: a serious real-world risk that could cause harm or major damage soon if ignored, but nothing is actively happening this second (a structural crack, a dangerous creature nearby but not attacking yet).\\n- medium: a real inconvenience or disruption to daily life, annoying and disruptive, but nobody is at risk (property damage, ongoing nuisance, malfunctioning magic item).\\n- low: a trivial annoyance, petty complaint, or pure bureaucracy with no real-world consequence at all (paperwork typos, minor insults, aesthetic complaints).\\n\\nExamples:\\n\\\"The well water turned green and something is pushing against the cover, three families drink from it\\\" -> critical\\n\\\"A structural crack in the town bridge, carts are avoiding it but it hasn't collapsed yet\\\" -> high\\n\\\"A garden gnome keeps staring into my window, I can't sleep\\\" -> medium\\n\\\"My rooster sings a semitone flat\\\" -> low\\n\\nRead the ticket and classify strictly by real-world consequence, not by how dramatically it's written.\\n\\nRespond only with the JSON schema provided, nothing else.\"}]}, \"contents\": [{\"parts\": [{\"text\": \"={{ $json.title }}\\n\\n{{ $json.description }}\"}]}], \"generationConfig\": {\"responseMimeType\": \"application/json\", \"responseSchema\": {\"type\": \"OBJECT\", \"properties\": {\"urgency\": {\"type\": \"STRING\", \"enum\": [\"low\", \"medium\", \"high\", \"critical\"]}, \"category\": {\"type\": \"STRING\", \"enum\": [\"monster_invasion\", \"bureaucracy\", \"broken_item\", \"magic_malfunction\", \"other\"]}, \"reasoning\": {\"type\": \"STRING\"}}, \"required\": [\"urgency\", \"category\"]}}}",
        "options": {}
      },
      "id": "72a29c90-2ee0-4b2c-a5c9-4eef000eb31a",
      "name": "Gemini - Classify Ticket",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        688,
        -208
      ],
      "credentials": {
        "httpQueryAuth": {
          "id": "",
          "name": "Gemini API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const original = $('Normalize Payload').first().json;\nconst geminiRaw = $input.first().json;\nconst text = geminiRaw.candidates[0].content.parts[0].text;\nconst parsed = JSON.parse(text);\n\nconst slaHoursByUrgency = { critical: 4, high: 24, medium: 72, low: 168 };\nconst fakeWaitYearsByUrgency = { critical: 350, high: 200, medium: 75, low: 12 };\n\nconst urgency = parsed.urgency;\nconst slaHours = slaHoursByUrgency[urgency] || 168;\nconst slaDeadline = new Date(Date.now() + slaHours * 60 * 60 * 1000).toISOString();\n\nreturn [{\n  json: {\n    title: original.title,\n    description: original.description,\n    submitter_name: original.submitter_name,\n    submitter_email: original.submitter_email,\n    urgency: parsed.urgency,\n    category: parsed.category,\n    reasoning: parsed.reasoning || '',\n    sla_deadline: slaDeadline,\n    fake_wait_years: fakeWaitYearsByUrgency[urgency] || 12\n  }\n}];"
      },
      "id": "46e9e906-2a12-4e4d-af3a-ea589426141b",
      "name": "Parse & Compute SLA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        -208
      ]
    },
