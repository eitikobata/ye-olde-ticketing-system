        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"from\": \"Kingdom's Complaints Office <correio@mail.eitikobata.com>\", \"to\": [\"{{ $json.submitter_email }}\"], \"subject\": \"Ticket Registered - Kingdom's Complaints Office\", \"html\": \"<p>Dear {{ $json.submitter_name }},</p><p>Your ticket <strong>{{ $json.title }}</strong> has been formally registered.</p><p>Classified as <strong>{{ $json.urgency }}</strong>, it will be reviewed in approximately <strong>{{ $json.fake_wait_years }} years</strong>.</p><p>&mdash; The Kingdom's Complaints Office</p>\"}",
